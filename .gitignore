# ============================================
# OS Specific
# ============================================

# Windows
Thumbs.db
*.lnk
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.Trash-*

# ============================================
# Project Specific
# ============================================

# Compiled output (ao invés de dist/)
/dist
/build
/out

# Temporary files
*.tmp
*.temp
.tmp/

# Logs
logs/
*.log
lerna-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# Coverage reports
coverage/
.nyc_output/

# Testing
.test/
test-results/

# ============================================
# Documentation
# ============================================

# Markdown backups (se não quiser versionar)
# *.md.bak

# OS temp files in docs
docs/.DS_Store

# ============================================
# Runtime Files
# ============================================

# Process manager
.pm2/
ecosystem.config.js.bak

# Cache
.cache/
.eslintcache

# ============================================
# Comments
# ============================================

# Este .gitignore está otimizado para:
# - Projetos Node.js / TypeScript
# - VS Code + IDE padrão
# - Sistemas operacionais (Windows, macOS, Linux)
# - Dependências npm e artefatos de build
