# ============================================

# VS Code
.vscode/
*.code-workspace
.history/
.idea/

# Visual Studio
.vs/
*.user
*.sln.docstates

# Sublime Text
*.sublime-project
*.sublime-workspace

# WebStorm / PyCharm / Other IDEs
.idea/
.gradle
.classpath
.project
.settings/
